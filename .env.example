# === REQUIRED ===
DISCORD_TOKEN=your_discord_bot_token
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
MONGO_URI=your_mongodb_connection_string

# === VOICE (optional — bot works without these) ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# === STOCKS (optional — scraper fallback works without this) ===
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# === MODELS (optional — defaults shown) ===
MODEL_CHAT=gemini-2.0-flash
MODEL_CLAUDE=claude-sonnet-4-5-20250929

# === SERVER (optional — Koyeb uses 8000) ===
PORT=8000
