# ══════════════════════════════════════════════
# Emily AI — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the bot to start.
# Variables marked [optional] have defaults or enable optional features.

# === CORE [REQUIRED] ===
DISCORD_TOKEN=your_discord_bot_token
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@your-cluster.mongodb.net/emily_brain_db?retryWrites=true&w=majority

# === OPENAI [optional — enables Whisper transcription + GPT-4.1-mini] ===
OPENAI_API_KEY=sk-your-openai-key

# === VOICE [optional — bot works without these] ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# === STOCKS [optional — scraper fallback works without this] ===
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# === AI MODELS [optional — defaults shown] ===
MODEL_CHAT=gemini-3.1-flash-lite-preview
MODEL_CLAUDE=claude-sonnet-4-5-20250929

# === WEB SEARCH [optional — DuckDuckGo fallback if not set] ===
GOOGLE_SEARCH_API_KEY=your_google_search_api_key
GOOGLE_SEARCH_CX=your_custom_search_engine_id

# === REDDIT [optional — enables !reddit, !rbuzz, !rticker] ===
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=emily-bot/1.0

# === SPOTIFY [optional — enables !music, !playlist] ===
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# === TWITTER/X [optional — enables auto film tweets] ===
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# === WHATSAPP [optional — Meta Cloud API] ===
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_API_VERSION=v17.0
WA_PHONE_NUMBER_ID=your_phone_number_id

# === SMS [optional — Africa's Talking] ===
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=
AT_ENVIRONMENT=sandbox

# === ADMIN ===
BOT_OWNER_ID=your_discord_user_id

# === JOURNAL PWA [optional — restricts CORS to your app URL] ===
JOURNAL_APP_URL=https://danielomulo-dev.github.io

# === SERVER [optional — Koyeb uses 8000] ===
PORT=8000
